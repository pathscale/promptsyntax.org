{
  "name": "promptsyntax.org",
  "version": "1.0.0",
  "description": "PromptSyntax - a vendor-neutral specification for prompt-execution intent and execution receipts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/pathscale/promptsyntax.org"
  },
  "scripts": {
    "start": "rsbuild dev",
    "dev": "rsbuild dev",
    "build": "npm run typecheck && rsbuild build && bun run cleanup",
    "typecheck": "tsc --noEmit",
    "preview": "rsbuild preview",
    "cleanup": "bun run src/scripts/cleanup.js",
    "lint": "biome check .",
    "format": "biome format . --write"
  },
  "license": "CC-BY-4.0",
  "dependencies": {
    "@pathscale/ui": "^1.2.11",
    "@solidjs/router": "^0.15.3",
    "clsx": "^2.1.1",
    "glob": "^11.0.3",
    "solid-js": "^1.9.5",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@iconify/tailwind4": "^1.0.6",
    "@rsbuild/core": "^1.3.20",
    "@rsbuild/plugin-babel": "^1.0.5",
    "@rsbuild/plugin-solid": "^1.0.5",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.17",
    "class-variance-authority": "^0.7.1",
    "compression-webpack-plugin": "^11.1.0",
    "cssnano": "^7.0.7",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "tailwindcss": "^4.0.7",
    "typescript": "^5.7.2"
  }
}
